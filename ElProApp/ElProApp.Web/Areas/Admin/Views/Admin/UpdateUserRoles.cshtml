@using ElProApp.Web.Models.Admin;
@model List<UserRolesViewModel>

@{
    ViewBag.Title = "Управление на роли";
    var allRoles = (List<string>)ViewBag.AllRoles;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Управление на роли</h2>

    <a href="/" class="btn btn-secondary">
        Начална страница
    </a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Потребител</th>
            <th>Премахни роли</th>
            <th>Добави роли</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>

                <td>
                    <form asp-action="UpdateUserRoles" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="userId" value="@user.UserId" />

                        <select name="roles" class="form-select" multiple>
                            @foreach (var role in user.Roles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>

                        <input type="hidden" name="state" value="remove" />
                        <button type="submit" class="btn btn-danger mt-2">Премахни</button>
                    </form>
                </td>

                <td>
                    <form asp-action="UpdateUserRoles" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="userId" value="@user.UserId" />

                        <select name="roles" class="form-select" multiple>
                            @foreach (var role in allRoles)
                            {
                                if (!user.Roles.Contains(role))
                                {
                                    <option value="@role">@role</option>
                                }
                            }
                        </select>

                        <input type="hidden" name="state" value="add" />
                        <button type="submit" class="btn btn-success mt-2">Добави</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>