@using System.Security.Claims
@model List<ElProApp.Web.Models.Search.SearchResultViewModel>

<h3>Резултати от търсенето</h3>

@if (Model.Any())
{
    <table class="table table-striped">
        <thead> <tr> <th>Тип</th> <th>Име</th> <th>Допълнителна информация</th> </tr> </thead>
        <tbody>
            @{
                var distinctTypes = Model.Select(x => x.Type).Distinct().ToList();
                int emlpoyeeCounter = 0;
                int buildingCounter = 0;
                int teamCounter = 0;
                int jobDoneCounter = 0;
                int jobCounter = 0;

        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                var isAdmin = User.IsInRole("Admin");
                var isOffice = User.IsInRole("OfficeManager");
                var isTech = User.IsInRole("Technician");
            }

            @foreach (var item in Model)
            {
                if (item.Type == "Employee")
                {
                    if (distinctTypes.Count > 1 && emlpoyeeCounter++ == 0)
                    {
                        <tr><td colspan="3" class="table-info text-center"><strong>Служители</strong></td></tr>
                    }
                    <tr>
                        <td>Служител</td>
                        <td>@item.Name</td>
                        <td>
                            @{
                                bool canView = isAdmin || item.Id == currentUserId;
                            }

                            @item.AdditionalInfo

                            @if (canView)
                            {
                                <div class="mt-1">
                                    <a asp-controller="Employee" asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Информация
                                    </a>
                                </div>
                            }
                        </td>
                    </tr>
                }
                else if (item.Type == "Building")
                {
                    if (distinctTypes.Count > 1 && buildingCounter++ == 0)
                    {
                        <tr><td colspan="3" class="table-info text-center"><strong>Сгради</strong></td></tr>
                    }
                    <tr>
                        <td>Сграда</td>
                        <td>@item.Name</td>
                        <td>
                            @item.AdditionalInfo

                            @if (isAdmin || isOffice || isTech)
                            {
                                <div class="mt-1">
                                    <a asp-controller="Building" asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Информация
                                    </a>
                                </div>
                            }
                        </td>
                    </tr>
                }
                else if (item.Type == "Team")
                {
                    if (distinctTypes.Count > 1 && teamCounter++ == 0)
                    {
                        <tr><td colspan="3" class="table-info text-center"><strong>Екипи</strong></td></tr>
                    }
                    <tr>
                        <td>Екип</td>
                        <td>@item.Name</td>
                        <td>
                            @item.AdditionalInfo

                            @if (isAdmin || isOffice || isTech)
                            {
                                <div class="mt-1">
                                    <a asp-controller="Team" asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Информация
                                    </a>
                                </div>
                            }
                        </td>
                    </tr>
                }
                else if (item.Type == "JobDone")
                {
                    if (distinctTypes.Count > 1 && jobDoneCounter++ == 0)
                    {
                        <tr><td colspan="3" class="table-info text-center"><strong>Свършена работа</strong></td></tr>
                    }
                    <tr>
                        <td>Свършена работа</td>
                        <td>@item.Name</td>
                        <td>
                            @item.AdditionalInfo

                            @if (isAdmin || isOffice || isTech)
                            {
                                <div class="mt-1">
                                    <a asp-controller="JobDone" asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Информация
                                    </a>
                                </div>
                            }
                        </td>
                    </tr>
                }
                else if (item.Type == "Job")
                {
                    if (distinctTypes.Count > 1 && jobCounter++ == 0)
                    {
                        <tr><td colspan="3" class="table-info text-center"><strong>Работа</strong></td></tr>
                    }
                    <tr>
                        <td>Работа</td>
                        <td>@item.Name</td>
                        <td>
                            @item.AdditionalInfo

                            @if (isAdmin || isOffice || isTech)
                            {
                                <div class="mt-1">
                                    <a asp-controller="Job" asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Информация
                                    </a>
                                </div>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination">
            @if ((int)ViewData["CurrentPage"] > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Search"
                       asp-route-pageNumber="@((int)ViewData["CurrentPage"] - 1)"
                       asp-route-query="@ViewData["SearchQuery"]"
                       asp-route-searchIn="@ViewData["SearchIn"]">
                        Предишна
                    </a>
                </li>
            }

            @for (int i = 1; i <= (int)ViewData["TotalPages"]; i++)
            {
                <li class="page-item @(i == (int)ViewData["CurrentPage"] ? "active" : "")">
                    <a class="page-link" asp-action="Search"
                       asp-route-pageNumber="@i"
                       asp-route-query="@ViewData["SearchQuery"]"
                       asp-route-searchIn="@ViewData["SearchIn"]">
                        @i
                    </a>
                </li>
            }

            @if ((int)ViewData["CurrentPage"] < (int)ViewData["TotalPages"])
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Search"
                       asp-route-pageNumber="@((int)ViewData["CurrentPage"] + 1)"
                       asp-route-query="@ViewData["SearchQuery"]"
                       asp-route-searchIn="@ViewData["SearchIn"]">
                        Следваща
                    </a>
                </li>
            }
    </ul>
</nav>

}
else
{
     <p>Няма намерени резултати.</p>
}
