@using ElProApp.Web.Models.Employee
@model EmployeeInputModel

@{
    ViewData["Title"] = "Добавяне";
}

<div class="page-container">

    <h2 class="section-title">Добавяне на служител</h2>

    <form asp-action="Add" method="post">

        <div class="mb-3">
            <label class="form-label">Име</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Фамилия</label>
            <input asp-for="LastName" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Дневно възнаграждение</label>
            <input asp-for="Wages" type="number" step="0.01" class="form-control" />
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Добави</button>
            <a asp-action="All" class="btn btn-primary">Назад</a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}