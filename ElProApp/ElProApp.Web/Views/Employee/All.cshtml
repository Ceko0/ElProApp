@using ElProApp.Web.Models.Employee
@using System.Security.Claims
@model ICollection<EmployeeViewModel>

@{
    ViewData["Title"] = "Списък със служители";
}

<div class="container mt-4">
    <h1 class="display-4 text-center">Списък със служители</h1>

    <div class="d-flex justify-content-between mb-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            Начална страница
        </a>
    </div>

    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Име</th>
                <th>Фамилия</th>
                <th>Екипи</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var employee in Model)
            {
                var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                var isAdmin = User.IsInRole("Admin") || User.IsInRole("OfficeManager");
                var isOwner = employee.UserId == currentUserId;

                <tr>
                    <td>@employee.Name</td>
                    <td>@employee.LastName</td>

                    <td>
                        @if (isOwner && employee.TeamsEmployeeBelongsTo != null && employee.TeamsEmployeeBelongsTo.Any(te => te != null))
                        {
                            <select class="form-select" onchange="location.href=this.value;">
                                <option selected disabled>Моите екипи</option>
                                @foreach (var teamMapping in employee.TeamsEmployeeBelongsTo.Where(te => te != null))
                                {
                                    <option value="@Url.Action("Details", "Team", new { id = teamMapping.Team.Id })">
                                        @teamMapping.Team.Name
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <td>
                        @if (isAdmin || isOwner)
                        {
                            <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-info btn-sm">
                                Детайли
                            </a>
                        }

                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-warning btn-sm">
                                Редактирай
                            </a>

                            <form asp-action="SoftDelete" asp-route-id="@employee.Id" method="post" style="display:inline;">
                                <button class="btn btn-danger btn-sm">
                                    Изтрий
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>