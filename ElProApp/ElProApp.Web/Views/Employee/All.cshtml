@using ElProApp.Web.Models.Employee
@using System.Security.Claims
@model ICollection<EmployeeViewModel>

@{
    ViewData["Title"] = "Служители";
}

<div class="page-container">

    <h2 class="section-title">Списък със служители</h2>

    <div class="mb-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            Начало
        </a>
    </div>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Име</th>
                <th>Фамилия</th>
                <th>Екипи</th>

                @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                {
                    <th>Заработка</th>
                }

                <th style="width:200px;">Действия</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var employee in Model)
            {
                var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                var isAdmin = User.IsInRole("Admin") || User.IsInRole("OfficeManager");
                var isOwner = employee.UserId == currentUserId;

                <tr>
                    <td>@employee.Name</td>
                    <td>@employee.LastName</td>

                    <td>
                        @if (isOwner && employee.TeamsEmployeeBelongsTo != null && employee.TeamsEmployeeBelongsTo.Any(te => te != null))
                        {
                            <select class="form-select" onchange="location.href=this.value;">
                                <option selected disabled>Моите екипи</option>
                                @foreach (var teamMapping in employee.TeamsEmployeeBelongsTo.Where(te => te != null))
                                {
                                    <option value="@Url.Action("Details", "Team", new { id = teamMapping.Team.Id })">
                                        @teamMapping.Team.Name
                                    </option>
                                }
                            </select>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    @if (isAdmin)
                    {
                        <td>@employee.MoneyToTake.ToString("F2") лв.</td>
                    }

                    <td>
                        @if (isAdmin || isOwner)
                        {
                            <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-details btn-sm">
                                Детайли
                            </a>
                        }

                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-success btn-sm">
                                Редактирай
                            </a>

                            <form asp-action="SoftDelete" asp-route-id="@employee.Id" method="post" style="display:inline;">
                                <button class="btn btn-danger btn-sm"
                                        onclick="return confirm('Сигурен ли си?')">
                                    Изтрий
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>