@using ElProApp.Web.Models.Employee
@model EmployeeViewModel

@{
    ViewData["Title"] = "Детайли";
}

<div class="page-container">

    <h2 class="section-title">@Model.Name @Model.LastName</h2>

    <div class="card mb-3">
        <div class="card-body">

            <p><strong>Име:</strong> @Model.Name</p>
            <p><strong>Фамилия:</strong> @Model.LastName</p>
            <p><strong>Дневно възнаграждение:</strong> @Model.Wages.ToString("C2", new System.Globalization.CultureInfo("bg-BG"))</p>
            <p><strong>Заработка:</strong> @Model.MoneyToTake.ToString("C2", new System.Globalization.CultureInfo("bg-BG"))</p>

            <p><strong>Екипи:</strong></p>

            @if (Model.TeamsEmployeeBelongsTo != null && Model.TeamsEmployeeBelongsTo.Any())
            {
                <ul>
                    @foreach (var teamMapping in Model.TeamsEmployeeBelongsTo)
                    {
                        <li>
                            <a href="@Url.Action("Details", "Team", new { id = teamMapping.Team.Id })">
                                @teamMapping.Team.Name
                            </a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <span class="text-muted">Няма екипи</span>
            }

            <p><strong>Потребител:</strong> @Model.User.UserName</p>

        </div>
    </div>

    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">
            Редактирай
        </a>

        <a asp-action="All" class="btn btn-primary">
            Назад
        </a>
    </div>

</div>