@using ElProApp.Web.Models.JobDone
@model JobDoneViewModel

<div class="page-container">

    <h2 class="section-title">@Model.Name</h2>

    <div class="card mb-3">
        <div class="card-body">

            <p><strong>Дни:</strong> @Model.DaysForJob</p>
            <p><strong>Сграда:</strong> @Model.Building.Name</p>
            <p><strong>Екип:</strong> @Model.Team.Name</p>

            <hr />

            <h5>Материали</h5>

            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Материал</th>
                        <th>Количество</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var material in Model.Materials)
                    {
                        <tr>
                            <td>@material.MaterialName</td>
                            <td>@material.Quantity</td>
                        </tr>
                    }
                </tbody>
            </table>

            <hr />

            <h5 class="text-end">
                Обща стойност: <strong>@Model.TotalCost лв.</strong>
            </h5>

        </div>
    </div>

    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">
            Редактирай
        </a>

        <a asp-action="All" class="btn btn-primary">
            Назад
        </a>
    </div>

</div>