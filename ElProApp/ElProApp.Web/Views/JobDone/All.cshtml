@using ElProApp.Web.Models.JobDone
@model ICollection<JobDoneViewModel>

@{
    ViewData["Title"] = "Всички изпълнени задачи";
}

<div class="container mt-4">
    <h1 class="display-4 text-center">Списък с изпълнени свършени работи</h1>

    <div class="d-flex justify-content-between mb-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            Начална страница
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager") || User.IsInRole("Technician"))
        {
            <a asp-controller="JobDone" asp-action="Add" class="btn btn-success">
                Добави свършена работа
            </a>
        }
    </div>

    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Име</th>
                <th>Екип</th>
                <th>Сграда</th>
                <th>Дни за изпълнение</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var jobDone in Model)
                {
                    <tr>
                        <td>@jobDone.Name</td>
                        <td>@jobDone.Team?.Name</td>
                        <td>@jobDone.Building?.Name</td>
                        <td>@jobDone.DaysForJob</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@jobDone.Id" class="btn btn-info btn-sm">
                                Детайли
                            </a>

                            @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@jobDone.Id" class="btn btn-warning btn-sm">
                                    Редактирай
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="SoftDelete" asp-route-id="@jobDone.Id" method="post" style="display:inline;">
                                    <button class="btn btn-danger btn-sm">
                                        Изтрий
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center">
                        Няма налични изпълнени задачи
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>