@using ElProApp.Web.Models.JobDone
@model ICollection<JobDoneViewModel>

@{
    ViewData["Title"] = "Свършена работа";
}

<div class="page-container">

    <h2 class="section-title">Списък със свършена работа</h2>

    <div class="mb-3 d-flex justify-content-between">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            Начало
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager") || User.IsInRole("Technician") || User.IsInRole("Worker"))
        {
            <a asp-controller="JobDone" asp-action="Add" class="btn btn-success">
                Добави работа
            </a>
        }
    </div>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Име</th>
                <th>Екип</th>
                <th>Сграда</th>
                <th>Дни</th>
                <th>Материали</th>
                <th style="width:200px;">Действия</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var jobDone in Model)
                {
                    <tr>
                        <td>@jobDone.Name</td>
                        <td>@jobDone.Team?.Name</td>
                        <td>@jobDone.Building?.Name</td>
                        <td>@jobDone.DaysForJob</td>
                        <td>@(jobDone.Materials?.Count ?? 0)</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@jobDone.Id" class="btn btn-details btn-sm">
                                Детайли
                            </a>

                            @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@jobDone.Id" class="btn btn-success btn-sm">
                                    Редактирай
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="SoftDelete"
                                      asp-route-id="@jobDone.Id"
                                      method="post"
                                      style="display:inline;">
                                    <button class="btn btn-danger btn-sm"
                                            onclick="return confirm('Сигурен ли си?')">
                                        Изтрий
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">
                        Няма налични записи
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>