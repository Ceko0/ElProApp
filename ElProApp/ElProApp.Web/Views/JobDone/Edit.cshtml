@using ElProApp.Web.Models.JobDone
@model JobDoneEditInputModel

<div class="container mt-4">
    <h1 class="display-4 text-center">Редактиране на свършена работа</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label asp-for="Name">Име</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label asp-for="DaysForJob">Дни</label>
            <input asp-for="DaysForJob" class="form-control" />
        </div>

        <div class="form-group mb-3">
            <label>Екип</label>
            <div class="form-control">@Model.Team.Name</div>
            <input type="hidden" asp-for="TeamId" />
        </div>

        <div class="form-group mb-3">
            <label>Сграда</label>
            <div class="form-control">@Model.Building.Name</div>
            <input type="hidden" asp-for="BuildingId" />
        </div>

        <hr />

        <h4>Материали</h4>

        <table class="table" id="materialsTable">
            <thead>
                <tr>
                    <th>Материал</th>
                    <th>Количество</th>
                    <th></th>
                </tr>
            </thead>
            <tbody id="materialsBody">
                @for (int i = 0; i < Model.Materials.Count; i++)
                {
                    <tr>
                        <td>
                            <select name="Materials[@i].MaterialId" class="form-control">
                                @foreach (var m in Model.MaterialsList)
                                {
                                    <option value="@m.Id"
                                            selected="@(m.Id == Model.Materials[i].MaterialId)">
                                        @m.Name
                                    </option>
                                }
                            </select>
                        </td>
                        <td>
                            <input type="number"
                                   name="Materials[@i].Quantity"
                                   value="@Model.Materials[i].Quantity"
                                   class="form-control"
                                   step="0.01" />
                        </td>
                        <td>
                            <button type="button" class="btn btn-danger remove-row">X</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="button" class="btn btn-primary mb-3" id="addRow">
            + Добави материал
        </button>

        <div class="d-flex justify-content-between">
            <button type="submit" class="btn btn-warning">Запази</button>
            <a asp-action="All" class="btn btn-secondary">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let index = @Model.Materials.Count;

        document.getElementById("addRow").addEventListener("click", function () {

            let options = `
                <option value="">Избери материал</option>
        @foreach (var m in Model.MaterialsList)
        {
                        <option value="@m.Id">@m.Name</option>
        }
            `;

            const row = `
            <tr>
                <td>
                    <select name="Materials[${index}].MaterialId" class="form-control">
                        ${options}
                    </select>
                </td>
                <td>
                    <input type="number" name="Materials[${index}].Quantity" class="form-control" step="0.01"/>
                </td>
                <td>
                    <button type="button" class="btn btn-danger remove-row">X</button>
                </td>
            </tr>`;

            document.getElementById("materialsBody").insertAdjacentHTML("beforeend", row);
            index++;
        });

        document.addEventListener("click", function (e) {
            if (e.target.classList.contains("remove-row")) {
                e.target.closest("tr").remove();
            }
        });
    </script>
}