@using ElProApp.Web.Models.JobDone
@model JobDoneEditInputModel

<div class="page-container">

    <h2 class="section-title">Редактиране на работа</h2>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" name="Name" value="@Model.Name" />
        <input type="hidden" name="TeamId" value="@Model.TeamId" />
        <input type="hidden" name="BuildingId" value="@Model.BuildingId" />

        <div class="mb-3">
            <label>Име</label>
            <div class="form-control-plaintext">@Model.Name</div>
        </div>

        <div class="mb-3">
            <label>Дни</label>
            <input asp-for="DaysForJob" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Екип</label>
            <div class="form-control-plaintext">@Model.Team.Name</div>
        </div>

        <div class="mb-3">
            <label>Сграда</label>
            <div class="form-control-plaintext">@Model.Building.Name</div>
        </div>

        <hr />

        <h5 class="section-title">Материали</h5>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Материал</th>
                    <th>Количество</th>
                    <th style="width:60px;"></th>
                </tr>
            </thead>

            <tbody id="materialsBody">
                @for (int i = 0; i < Model.Materials.Count; i++)
                {
                    <tr>
                        <td>
                            <select name="Materials[@i].MaterialId" class="form-control material-select">
                                @foreach (var m in Model.MaterialsList)
                                {
                                    <option value="@m.Id" selected="@(m.Id == Model.Materials[i].MaterialId)">
                                        @m.Name
                                    </option>
                                }
                            </select>
                        </td>

                        <td>
                            <input type="number"
                                   name="Materials[@i].Quantity"
                                   value="@Model.Materials[i].Quantity"
                                   class="form-control"
                                   step="0.01" />
                        </td>

                        <td>
                            <button type="button" class="btn btn-danger btn-sm remove-row">X</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="button" class="btn btn-success mb-3" id="addRow">
            + Добави материал
        </button>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Запази</button>
            <a asp-action="All" class="btn btn-primary">Назад</a>
        </div>

    </form>

</div>

@section Scripts {
    <script>
            let index = @Model.Materials.Count;

            const materials = @Html.Raw(
        System.Text.Json.JsonSerializer.Serialize(
            Model.MaterialsList.Select(x => new { id = x.Id, name = x.Name })
        )
    );

            function getSelectedMaterials() {
                return Array.from(document.querySelectorAll(".material-select"))
                    .map(x => x.value)
                    .filter(x => x !== "");
            }

            function renderOptions(select, selectedValue = "") {
                const selected = getSelectedMaterials();

                select.innerHTML = `<option value="">Избери материал</option>`;

                materials.forEach(m => {
                    if (!selected.includes(m.id) || m.id === selectedValue) {
                        const option = document.createElement("option");
                        option.value = m.id;
                        option.textContent = m.name;

                        if (m.id === selectedValue)
                            option.selected = true;

                        select.appendChild(option);
                    }
                });
            }

            function createRow(selectedValue = "") {
                const tr = document.createElement("tr");

                tr.innerHTML = `
                    <td><select name="Materials[${index}].MaterialId" class="form-control material-select"></select></td>
                    <td><input type="number" name="Materials[${index}].Quantity" class="form-control" step="0.01" /></td>
                    <td><button type="button" class="btn btn-danger btn-sm remove-row">X</button></td>
                `;

                document.getElementById("materialsBody").appendChild(tr);

                const select = tr.querySelector(".material-select");

                renderOptions(select, selectedValue);

                select.addEventListener("change", () => {
                    document.querySelectorAll(".material-select").forEach(s => {
                        const val = s.value;
                        renderOptions(s, val);
                    });
                });

                index++;
            }

            function reindexRows() {
                const rows = document.querySelectorAll("#materialsBody tr");

                rows.forEach((row, i) => {
                    const select = row.querySelector("select");
                    const input = row.querySelector("input[type='number']");

                    select.name = `Materials[${i}].MaterialId`;
                    input.name = `Materials[${i}].Quantity`;
                });

                index = rows.length;
            }

            document.getElementById("addRow").addEventListener("click", () => {
                createRow();
            });

            document.addEventListener("click", function (e) {
                if (e.target.classList.contains("remove-row")) {
                    e.target.closest("tr").remove();

                    reindexRows();

                    document.querySelectorAll(".material-select").forEach(s => {
                        const val = s.value;
                        renderOptions(s, val);
                    });
                }
            });
    </script>
}