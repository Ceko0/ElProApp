@using ElProApp.Web.Models.Job
@model ICollection<JobViewModel>

@{
    ViewData["Title"] = "Списък с работа";
}

<div class="container mt-4">
    <h1 class="display-4 text-center">Списък с работа</h1>

    <div class="d-flex justify-content-between mb-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            Начална страница
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
        {
            <a asp-controller="Job" asp-action="Add" class="btn btn-success">
                Добави работа
            </a>
        }
    </div>

    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Име</th>
                <th>Цена за 1 бр / 1 метър</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var job in Model)
                {
                    <tr>
                        <td>@job.Name</td>
                        <td>@job.Price.ToString("C2", new System.Globalization.CultureInfo("bg-BG"))</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@job.Id" class="btn btn-info btn-sm">
                                Детайли
                            </a>

                            @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@job.Id" class="btn btn-warning btn-sm">
                                    Редактирай
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="SoftDelete" asp-route-id="@job.Id" method="post" style="display:inline;">
                                    <button class="btn btn-danger btn-sm">
                                        Изтрий
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center">Няма налична информация за работа.</td>
                </tr>
            }
        </tbody>
    </table>
</div>