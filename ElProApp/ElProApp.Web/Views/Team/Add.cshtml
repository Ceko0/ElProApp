@using ElProApp.Web.Models.Team
@model TeamInputModel

<div class="page-container">

    <h2 class="section-title">Добавяне на екип</h2>

    <form asp-action="Add" method="post">

        <div class="mb-3">
            <label>Име</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Сграда</label>
            <select asp-for="SelectedBuildingId"
                    asp-items="@(new SelectList(Model.BuildingWithTeam, "Id", "Name"))"
                    class="form-control">
                <option value="">Избери</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Служители</label>

            @if (Model.AvailableEmployees != null && Model.AvailableEmployees.Any())
            {
                foreach (var employee in Model.AvailableEmployees)
                {
                    <div class="form-check">
                        <input type="checkbox" name="SelectedEmployeeIds" value="@employee.Id"
                               class="form-check-input"
                        @(Model.SelectedEmployeeIds.Contains(employee.Id) ? "checked" : "") />
                        <label class="form-check-label">@employee.Name</label>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Няма служители</p>
            }
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Добави</button>
            <a asp-action="All" class="btn btn-primary">Назад</a>
        </div>

    </form>

</div>