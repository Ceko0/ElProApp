@using ElProApp.Web.Models.Team
@model TeamViewModel

<div class="page-container">

    <h2 class="section-title">Екип: @Model.Name</h2>

    <div class="card mb-3">
        <div class="card-body">

            <p><strong>Име:</strong> @Model.Name</p>

            <hr />

            <h5>Сгради</h5>

            @if (Model.BuildingWithTeam != null && Model.BuildingWithTeam.Any())
            {
                <ul>
                    @foreach (var building in Model.BuildingWithTeam)
                    {
                        <li>@building.Building?.Name (@building.Building?.Location)</li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Няма сгради</p>
            }

            <hr />

            <h5>Служители</h5>

            @if (Model.EmployeesInTeam != null && Model.EmployeesInTeam.Any())
            {
                <ul>
                    @foreach (var employee in Model.EmployeesInTeam)
                    {
                        <li>@employee.Employee?.Name @employee.Employee?.LastName</li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">Няма служители</p>
            }

        </div>
    </div>

    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">Редактирай</a>
        <a asp-action="All" class="btn btn-primary">Назад</a>
    </div>

</div>