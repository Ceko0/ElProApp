@using ElProApp.Web.Models.Team
@model TeamEditInputModel

<div class="container mt-4">
    <h1 class="display-4 text-center">Редактиране на екип - @Model.Name</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Име на екипа</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        @if (Model.BuildingWithTeam != null && Model.BuildingWithTeam.Any())
        {
            <div class="mb-3">
                <label class="form-label">Сгради</label>

                @foreach (var building in Model.BuildingWithTeam)
                {
                    var isSelected = Model.BuildingWithTeamIds.Contains(building.Id);

                    <div class="form-check">
                        <input type="checkbox"
                               name="BuildingWithTeamIds"
                               value="@building.Id"
                               class="form-check-input"
                        @(isSelected ? "checked" : "") />
                        <label class="form-check-label">@building.Name</label>
                    </div>
                }
            </div>
        }

        @if (Model.EmployeesInTeam != null && Model.EmployeesInTeam.Any())
        {
            <div class="mb-3">
                <label class="form-label">Служители</label>

                @foreach (var e in Model.EmployeesInTeam)
                {
                    var isSelected = Model.EmployeesInTeamIds.Contains(e.Id);

                    <div class="form-check">
                        <input type="checkbox"
                               name="EmployeesInTeamIds"
                               value="@e.Id"
                               class="form-check-input"
                        @(isSelected ? "checked" : "") />
                        <label class="form-check-label">@e.Name @e.LastName</label>
                    </div>
                }
            </div>
        }

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Запази</button>
            <a asp-action="All" class="btn btn-primary">Назад</a>
        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}