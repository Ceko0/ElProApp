@using ElProApp.Web.Models.Team
@using System.Security.Claims
@model ICollection<TeamViewModel>

@{
    ViewData["Title"] = "Екипи";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="page-container">

    <h2 class="section-title">Списък с екипи</h2>

    <div class="mb-3 d-flex justify-content-between">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Начало</a>

        @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
        {
            <a asp-controller="Team" asp-action="Add" class="btn btn-success">Добави екип</a>
        }
    </div>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Име</th>
                <th>Служители</th>
                <th>Сгради</th>
                <th style="width:200px;">Действия</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var team in Model)
                {
                    var isUserInTeam = team.EmployeesInTeam != null &&
                    team.EmployeesInTeam.Any(e => e.Employee.UserId.ToString() == currentUserId);

                    <tr>
                        <td>@team.Name</td>

                        <td>
                            @if (team.EmployeesInTeam != null && team.EmployeesInTeam.Any())
                            {
                                <ul class="mb-0">
                                    @foreach (var employee in team.EmployeesInTeam)
                                    {
                                        <li>@employee.Employee.Name @employee.Employee.LastName</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>

                        <td>
                            @if (team.BuildingWithTeam != null && team.BuildingWithTeam.Any())
                            {
                                <ul class="mb-0">
                                    @foreach (var building in team.BuildingWithTeam.Where(b => b.Building != null))
                                    {
                                        <li>@building.Building.Name</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>

                        <td>
                            @if (isUserInTeam || User.IsInRole("Admin"))
                            {
                                <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-details btn-sm">
                                    Детайли
                                </a>
                            }

                            @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@team.Id" class="btn btn-success btn-sm">
                                    Редактирай
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="SoftDelete" asp-route-id="@team.Id" method="post" style="display:inline;">
                                    <button class="btn btn-danger btn-sm" onclick="return confirm('Сигурен ли си?')">
                                        Изтрий
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Няма налични екипи</td>
                </tr>
            }
        </tbody>
    </table>

</div>