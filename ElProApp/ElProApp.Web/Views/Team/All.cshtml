@using ElProApp.Web.Models.Team
@using System.Security.Claims
@model ICollection<TeamViewModel>

@{
    ViewData["Title"] = "Списък с екипи";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-4">
    <h1 class="display-4 text-center">Списък с екипи</h1>

    <div class="d-flex justify-content-between mb-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            Начална страница
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
        {
            <a asp-controller="Team" asp-action="Add" class="btn btn-success">
                Добави екип
            </a>
        }
    </div>

    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Име на екипа</th>
                <th>Служители</th>
                <th>Сгради</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var team in Model)
                {
                    var isUserInTeam = team.EmployeesInTeam != null &&
                    team.EmployeesInTeam.Any(e => e.Employee.UserId.ToString() == currentUserId);

                    <tr>
                        <td>@team.Name</td>

                        <td>
                            @if (team.EmployeesInTeam != null && team.EmployeesInTeam.Any())
                            {
                                <ul>
                                    @foreach (var employee in team.EmployeesInTeam)
                                    {
                                        <li>@employee.Employee.Name @employee.Employee.LastName</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>Няма налични служители</span>
                            }
                        </td>

                        <td>
                            @if (team.BuildingWithTeam != null && team.BuildingWithTeam.Any())
                            {
                                <ul>
                                    @foreach (var building in team.BuildingWithTeam.Where(b => b.Building != null))
                                    {
                                        <li>@building.Building.Name</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>Няма налични сгради</span>
                            }
                        </td>

                        <td>
                            @if (isUserInTeam || User.IsInRole("Admin"))
                            {
                                <a asp-action="Details" asp-route-id="@team.Id" class="btn btn-info btn-sm">
                                    Детайли
                                </a>
                            }

                            @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@team.Id" class="btn btn-warning btn-sm">
                                    Редактирай
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="SoftDelete" asp-route-id="@team.Id" method="post" style="display:inline;">
                                    <button class="btn btn-danger btn-sm">
                                        Изтрий
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Няма налични екипи</td>
                </tr>
            }
        </tbody>
    </table>
</div>