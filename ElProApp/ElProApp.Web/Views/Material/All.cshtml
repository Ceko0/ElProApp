@using ElProApp.Web.Models.Material
@model ICollection<MaterialViewModel>

@{
    ViewData["Title"] = "Материали";
}

<div class="page-container">

    <h2 class="section-title">Материали</h2>

    <div class="mb-3 d-flex justify-content-between">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            Начало
        </a>

        @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager") || User.IsInRole("Technician"))
        {
            <a asp-controller="Material" asp-action="Add" class="btn btn-success">
                Добави материал
            </a>
        }
    </div>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Материал</th>
                <th style="width:260px;">Действия</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var material in Model)
                {
                    <tr>
                        <td>@material.Name</td>

                        <td>
                            <a asp-action="Details" asp-route-id="@material.Id" class="btn btn-details btn-sm">
                                Детайли
                            </a>

                            @if (User.IsInRole("Admin") || User.IsInRole("OfficeManager"))
                            {
                                <a asp-action="Edit" asp-route-id="@material.Id" class="btn btn-success btn-sm">
                                    Редакция
                                </a>

                                <a asp-action="Prices"
                                   asp-route-materialId="@material.Id"
                                   class="btn btn-primary btn-sm">
                                    Цени
                                </a>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="SoftDelete"
                                      asp-route-id="@material.Id"
                                      method="post"
                                      style="display:inline;">
                                    <button class="btn btn-danger btn-sm">
                                        Изтрий
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" class="text-center">Няма материали</td>
                </tr>
            }
        </tbody>
    </table>

</div>