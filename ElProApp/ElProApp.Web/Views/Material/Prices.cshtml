@model ICollection<ElProApp.Web.Models.Material.BuildingMaterialPriceViewModel>

<div class="page-container">

    <h2 class="section-title">Цени по обекти</h2>

    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Сграда</th>
                <th>Цена</th>
                <th style="width:120px;">Действия</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.BuildingName</td>
                    <td>@item.Price</td>
                    <td>
                        <a asp-action="SetPrice"
                           asp-route-buildingId="@item.BuildingId"
                           asp-route-materialId="@item.MaterialId"
                           class="btn btn-success btn-sm">
                            Редактирай
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="All" class="btn btn-primary">Назад</a>

</div>