@using ElProApp.Web.Models.Material
@model MaterialInputModel

<div class="container mt-4">
    <h1 class="display-4 text-center">Добавяне на материал</h1>

    <form asp-action="Add" method="post">
        <div class="form-group mb-3">
            <label asp-for="Name" class="control-label">Име на материала</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <button type="submit" class="btn btn-success btn-sm">
                Добави материал
            </button>

            <a asp-action="All" class="btn btn-secondary">
                Списък с материали
            </a>

            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                Начална страница
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}