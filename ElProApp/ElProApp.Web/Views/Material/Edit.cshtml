@using ElProApp.Web.Models.Material
@model MaterialEditInputModel

@{
    ViewData["Title"] = "Редактиране на материал";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="display-4 text-center">
        Редактиране на материал - @Model.Name
    </h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label asp-for="Name" class="control-label">Име на материала</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <button type="submit" class="btn btn-warning">
                Запази
            </button>

            <div>
                <a asp-action="All" class="btn btn-secondary me-2">
                    Списък с материали
                </a>

                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
                    Начална страница
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}