@using ElProApp.Web.Models.Material
@model List<BuildingMaterialViewModel>

@{
    ViewData["Title"] = "Редакция на количества";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="text-center">Редакция на количества</h1>

    <form asp-action="EditQuantities" method="post">

        <input type="hidden" name="buildingId" value="@Model.First().BuildingId" />

        <table class="table table-bordered mt-4">
            <thead>
                <tr>
                    <th>Материал</th>
                    <th>Количество</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td>
                            @Model[i].MaterialName
                            <input type="hidden" asp-for="@Model[i].MaterialId" />
                            <input type="hidden" asp-for="@Model[i].BuildingId" />
                        </td>
                        <td>
                            <input asp-for="@Model[i].Quantity" class="form-control" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button class="btn btn-success">Запази</button>
        <a asp-controller="Building" asp-action="Details" asp-route-id="@Model.First().BuildingId" class="btn btn-secondary">Назад</a>

    </form>
</div>