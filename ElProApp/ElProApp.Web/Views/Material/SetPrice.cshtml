@using ElProApp.Web.Models.Material
@model BuildingMaterialPriceInputModel

<div class="page-container">

    <h2 class="section-title">Задаване на цена</h2>

    <form asp-action="SetPrice" method="post">

        <div class="mb-3">
            <label>Сграда</label>
            <select asp-for="BuildingId" asp-items="Model.Buildings" class="form-control">
                <option value="">-- избери --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Материал</label>
            <select asp-for="MaterialId" asp-items="Model.Materials" class="form-control">
                <option value="">-- избери --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Цена</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Запази</button>
            <a asp-action="All" class="btn btn-primary">Назад</a>
        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}