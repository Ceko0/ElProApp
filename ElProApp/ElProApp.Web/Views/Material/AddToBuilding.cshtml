@model ElProApp.Web.Models.Material.BuildingMaterialInputModel

<div class="page-container">

    <h2 class="section-title">Добавяне на материал към обект</h2>

    <form asp-action="AddToBuilding" method="post">

        <div class="mb-3">
            <label>Сграда</label>
            <select asp-for="BuildingId" asp-items="Model.Buildings" class="form-control">
                <option value="">-- избери --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Материал</label>
            <select asp-for="MaterialId" asp-items="Model.Materials" class="form-control">
                <option value="">-- избери --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Количество</label>
            <input asp-for="Quantity" class="form-control" />
        </div>

        <div class="mt-3">
            <button class="btn btn-success">Добави</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Начало</a>
        </div>

    </form>

</div>